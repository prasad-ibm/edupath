# Server
PORT=4000
NODE_ENV=development

# JWT — change to a long random string in production
JWT_SECRET=dev-secret-change-in-production

# Railway PostgreSQL
# Railway auto-sets this when you add a Postgres plugin to your project.
# For local dev: copy the connection string from Railway's Postgres plugin > Connect tab.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Frontend URL (set to your Railway frontend URL in production)
FRONTEND_URL=http://localhost:5174

# ── ClassLink (add when ready for school deployment) ──────────────────────
# CLASSLINK_CLIENT_ID=your-classlink-client-id
# CLASSLINK_CLIENT_SECRET=your-classlink-client-secret
# CLASSLINK_REDIRECT_URI=https://your-backend.railway.app/auth/callback
