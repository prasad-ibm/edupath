# Server
PORT=4000
FRONTEND_URL=http://localhost:5173

# JWT — change to a strong random string in production
JWT_SECRET=dev-secret-change-in-production

# Supabase (optional for local dev — progress won't persist without it)
# Get from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── ClassLink (add when ready for school deployment) ──────────────────────
# CLASSLINK_CLIENT_ID=your-classlink-client-id
# CLASSLINK_CLIENT_SECRET=your-classlink-client-secret
# CLASSLINK_REDIRECT_URI=http://localhost:4000/auth/callback
